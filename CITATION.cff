cff-version: 1.2.0
message: "If you use SIGMA Guard, please cite it as below."
title: "SIGMA Guard: Deterministic Structural Contradiction Detection for Graph Databases"
type: software
authors:
  - family-names: Volk
    given-names: Jason Leonard
    email: jason@invariant.pro
    affiliation: Invariant Research
version: 0.3.1
date-released: 2026-06-07
url: "https://github.com/Jasonleonardvolk/sigma-guard"
